/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: upgrade-insecure-requests; default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.sheetjs.com https://cdn.jsdelivr.net https://js.sentry-cdn.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' https://*.ingest.us.sentry.io
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

/app.js
  Content-Type: application/javascript; charset=utf-8

/api.js
  Content-Type: application/javascript; charset=utf-8

/infrastructure.js
  Content-Type: application/javascript; charset=utf-8

/modules.js
  Content-Type: application/javascript; charset=utf-8

/ai-assistant.js
  Content-Type: application/javascript; charset=utf-8

/styles.css
  Content-Type: text/css; charset=utf-8
